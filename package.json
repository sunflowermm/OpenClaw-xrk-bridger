{
  "name": "@sunflowermm/openclaw-xrk-bridger",
  "version": "0.2.10",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "description": "OpenClaw 通道插件：通过 XRK-AGT 自定义 Tasker 转发 QQ 事件。",
  "type": "module",
  "main": "dist/index.js",
  "author": "XRK",
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "publish:npm": "npm publish --registry https://registry.npmjs.org/ --access public",
    "publish:github": "node scripts/publish-github.js",
    "publish:both": "npm run publish:npm && npm run publish:github",
    "release": "npm version patch && npm run publish:both"
  },
  "dependencies": {
    "openclaw": "^2026.3.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "channel": {
      "id": "xrk-agt",
      "label": "XRK-AGT Bridge",
      "selectionLabel": "XRK-AGT (Bridge)",
      "docsPath": "/channels/xrk-agt",
      "blurb": "通过 XRK-AGT Tasker 转发 QQ/事件。",
      "order": 66
    }
  }
}
