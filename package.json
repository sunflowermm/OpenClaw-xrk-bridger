{
  "name": "@sunflowermm/openclaw-xrk-bridger",
  "version": "0.1.7",
  "description": "OpenClaw 通道插件：通过 XRK-AGT 自定义 Tasker 转发 QQ 事件。",
  "type": "module",
  "main": "dist/index.js",
  "author": "XRK",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sunflowermm/openclaw-xrk-bridger.git"
  },
  "keywords": ["openclaw", "xrk-agt", "qq", "onebot", "bridge", "plugin"],
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "openclaw": "^2026.3.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "channel": {
      "id": "xrk-agt",
      "label": "XRK-AGT Bridge",
      "selectionLabel": "XRK-AGT (Bridge)",
      "docsPath": "/channels/xrk-agt",
      "blurb": "通过 XRK-AGT Tasker 转发 QQ/事件。",
      "order": 66
    }
  }
}
